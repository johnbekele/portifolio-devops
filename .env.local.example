# ── Turso (libSQL) ──────────────────────────────────────────────
# Create a database at https://turso.tech/ (free tier).
#   turso db create portfolio
#   turso db show portfolio --url
#   turso db tokens create portfolio
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Auth.js (NextAuth v5) ──────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-32-byte-secret

# ── Google OAuth ───────────────────────────────────────────────
# Console: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
# (and http://localhost:3000/api/auth/callback/google for local dev)
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# ── Admin allowlist ────────────────────────────────────────────
# Comma-separated list of Google account emails that may access /admin.
ADMIN_EMAILS=you@gmail.com

# ── Vercel Blob ────────────────────────────────────────────────
# Get from your Vercel project: Storage -> Blob -> .env settings.
# Vercel may name it BLOB1_READ_WRITE_TOKEN or BLOB2_READ_WRITE_TOKEN
# when more than one Blob store is connected. The app accepts any of these.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# ── Anthropic (AI project autofill) ────────────────────────────
# Optional. Powers the "Generate with AI" button on the project edit page.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx
# Optional override for the model.
# ANTHROPIC_MODEL=claude-sonnet-4-5
